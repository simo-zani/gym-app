# Supabase — copia in .env e compila con i valori del tuo progetto
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# Solo per lo script di seed wger (npm run seed:wger). NON usata dal client,
# NON committare il valore reale. Project Settings → API → service_role.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
